# --- Python virtual environment ---
venv/
.venv/

# --- Data (keep the folder, ignore its contents) ---
data/*
!data/.gitkeep

# --- Trained model weights (regenerated by training; see README) ---
# Models can be reproduced by running the training script — they are not committed.
models/*
!models/.gitkeep
*.pth
*.pt
*.onnx
*.ckpt

# --- Python caches ---
__pycache__/
*.py[cod]
*.egg-info/
.pytest_cache/

# --- Jupyter ---
.ipynb_checkpoints/

# --- Environment / secrets ---
.env

# --- macOS ---
.DS_Store

# --- IDEs ---
.vscode/
.idea/
